HOST=0.0.0.0
PORT=3080
NODE_ENV=production
TRUST_PROXY=1
DOMAIN_CLIENT=http://192.168.1.66:3080
DOMAIN_SERVER=http://192.168.1.66:3080
NO_INDEX=true

# Ollama + MCP only (no OpenAI endpoint)
ENDPOINTS=custom

# Auth / mode
SINGLE_USER_MODE=true
ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=false
MIN_PASSWORD_LENGTH=1
JWT_SECRET=@JWT_SECRET@
JWT_REFRESH_SECRET=@JWT_REFRESH_SECRET@
SESSION_EXPIRY=2592000000
REFRESH_TOKEN_EXPIRY=7776000000
DISABLE_AGENTS=false
AGENTS_ENABLED=true

# DB/cache/search
MONGO_URI=mongodb://mongo:27017/librechat
MONGO_DB=librechat
REDIS_URI=redis://redis:6379
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=librechat_meili_master_key

# Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT=600000
OLLAMA_LONG_OPERATION_TIMEOUT=1800000

# Stable Diffusion
SD_WEBUI_URL=http://host.docker.internal:7860

# Defaults
DEFAULT_ENDPOINT=custom
DEFAULT_MODEL=llava:latest

# Storage/logs
STORAGE_DIR=/app/uploads
LOG_LEVEL=info

# Optional email
EMAIL_PROVIDER=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
